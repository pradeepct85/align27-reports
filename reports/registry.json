name: Update Report Registry
on:
  push:
    paths:
      - 'reports/20**.html'

permissions:
  contents: write

jobs:
  update-registry:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Generate registry.json
        run: |
          python3 -c "
          import os, json
          files = [f for f in os.listdir('reports') if f.endswith('.html') and f[0].isdigit()]
          dates = sorted([f.replace('.html','') for f in files], reverse=True)
          with open('reports/registry.json','w') as fp:
              json.dump(dates, fp, indent=2)
          print(f'Registry updated: {len(dates)} reports')
          "

      - name: Commit registry
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add reports/registry.json
          git diff --staged --quiet || git commit -m "chore: update registry.json [skip ci]"
          git push
